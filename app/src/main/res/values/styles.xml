<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Card style -->
    <style name="CardStyle">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:elevation">2dp</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Section label -->
    <style name="SectionLabel">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Button styles -->
    <style name="BtnGenerate" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/btn_generate_start</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnStop" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/btn_generate_stop</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="BtnText" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
